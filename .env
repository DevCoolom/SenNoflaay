# Server Configuration
NODE_ENV=development
PORT=3000

# Database - Supabase PostgreSQL
# For production: Use your Supabase project URL and keys
# For local development: Use the Postgres service from docker-compose
SUPABASE_URL=http://localhost:54321
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Local PostgreSQL (for docker-compose)
DB_USER=sennoflaay
DB_PASSWORD=sennoflaay123
DB_NAME=sennoflaay

# Authentication
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Google Gemini API (optional)
GEMINI_API_KEY=

# GitHub Integration (optional)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REPO_OWNER=
GITHUB_REPO_NAME=

# Application URLs
APP_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Deployment Secrets (for GitHub Actions)
# RENDER_DEPLOY_HOOK_URL=https://api.render.com/deploy/srv-xxx?key=yyy
